# ─────────────────────────────────────────────
#  Sunrise Real Estate – Environment Variables
#  Copy this file to .env and fill in the values
# ─────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/sunrise-realestate?retryWrites=true&w=majority

# JWT
JWT_SECRET=replace_with_a_long_random_secret_string_at_least_64_chars
JWT_EXPIRES_IN=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Admin seed (used ONLY on first run to create the admin account)
ADMIN_USERNAME=yashthakkar
ADMIN_PASSWORD=change_this_to_a_strong_password

# Frontend origin (for CORS)
FRONTEND_URL=http://localhost:3000
